{
  "name": "openkit-developer-tools",
  "version": "0.1.0",
  "private": true,
  "description": "Privacy-first developer toolkit with 100+ professional-grade utilities for software engineers",
  "keywords": [
    "developer-tools",
    "engineering",
    "devtools",
    "software-development",
    "privacy-first"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "check:deps": "./scripts/check-deps.sh",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:headed": "playwright test --headed",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:mobile": "playwright test --project=mobile-chrome --project=mobile-safari",
    "test:critical": "playwright test e2e/critical-tools.spec.ts",
    "test:category": "playwright test e2e/category-coverage.spec.ts",
    "test:common": "playwright test e2e/common-features.spec.ts",
    "test:performance": "playwright test e2e/performance.spec.ts",
    "test:errors": "playwright test e2e/error-scenarios.spec.ts",
    "test:darkmode": "playwright test e2e/dark-mode.spec.ts",
    "test:pin": "playwright test e2e/pin-functionality.spec.ts",
    "test:data-format": "playwright test e2e/data-format-tools.spec.ts",
    "test:generators": "playwright test e2e/generators-utilities.spec.ts",
    "test:generators:headed": "playwright test e2e/generators-utilities.spec.ts --headed",
    "test:generators:runner": "tsx e2e/run-generator-tests.ts",
    "test:report": "playwright show-report test-results/html-report",
    "test:codegen": "playwright codegen http://localhost:3000",
    "lighthouse": "lhci autorun",
    "lighthouse:desktop": "lhci autorun --collect.settings.preset=desktop",
    "lighthouse:mobile": "lhci autorun --collect.settings.preset=mobile"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@types/canvas-confetti": "^1.9.0",
    "@types/diff": "^8.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "^3.0.3",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cron-parser": "^5.5.0",
    "cronstrue": "^3.11.0",
    "diff": "^8.0.3",
    "dompurify": "^3.3.1",
    "html2canvas-pro": "^1.6.6",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.563.0",
    "next": "16.1.7",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
"tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.58.1",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "lighthouse": "^13.0.1",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
